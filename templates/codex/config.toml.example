# Optional named profiles.
[profiles.lightweight]
model = "gpt-4.1"
approval_policy = "on-request"

[profiles.deep-review]
model = "gpt-5.4"
model_reasoning_effort = "medium"
model_verbosity = "low"
approval_policy = "on-request"

# Start from a trimmed environment and opt variables in deliberately.
[shell_environment_policy]
inherit = "core"
include_only = ["PATH", "HOME", "LANG", "LC_ALL", "TERM"]
exclude = ["*_TOKEN", "*_SECRET", "*_KEY", "AWS_*", "AZURE_*"]
