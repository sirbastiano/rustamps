# .codex/config.toml.example
# Copy the parts that fit your environment.

# Read more of each AGENTS file before truncation becomes a problem.
project_doc_max_bytes = 65536

# Treat alternate instruction file names as project guidance when needed.
project_doc_fallback_filenames = ["TEAM_GUIDE.md", ".agents.md"]

# Keep default responses compact in interactive coding sessions.
model_verbosity = "low"

# Reduce noisy reasoning events in CI or terminal logs if desired.
hide_agent_reasoning = true

[features]
multi_agent = true

[agents]
max_threads = 6
max_depth = 1
contract_version = "1.0"
depth_profiles = { default = 1, high_risk = 2 }

[agents.explorer]
description = "Read-only codebase explorer for gathering evidence before changes are proposed."
config_file = "agents/explorer.toml"
role_scope = "discovery"
risk_level = "low"
allow_parallel = true
parallel_cap = 2
serial_required = false
handoff_mode = "parallel-review"

[agents.planner]
description = "Read-only planner for mapping blast radius, invariants, and the smallest correct implementation path."
config_file = "agents/planner.toml"
role_scope = "coordination"
risk_level = "medium"
allow_parallel = false
parallel_cap = 1
serial_required = true
handoff_mode = "stage-gate"

[agents.feature-builder]
description = "Top-level coding orchestrator that routes through planning, implementation, validation, review, and gate stages."
config_file = "agents/feature-builder.toml"
role_scope = "orchestration"
risk_level = "high"
allow_parallel = true
parallel_cap = 2
serial_required = true
handoff_mode = "multi-stage"

[agents.architecture-reviewer]
description = "Read-only architecture reviewer for boundaries, state flow, dependency direction, and change schematic risk."
config_file = "agents/architecture-reviewer.toml"
role_scope = "analysis"
risk_level = "high"
allow_parallel = true
parallel_cap = 1
serial_required = false
handoff_mode = "parallel-review"

